# LLM (default: Gemini direct — lowest latency/cost for this demo)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional fallbacks
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Instagram
APIFY_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=apify/instagram-scraper

# Vector DB — Qdrant Cloud (recommended for production)
QDRANT_URL=https://your-cluster.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
# Local fallback when URL/key are empty
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=video_chunks

# Redis (session cache + LangGraph checkpointer)
REDIS_URL=redis://localhost:6379/0

# Embeddings (FastEmbed ONNX — low RAM; use all-MiniLM-L6-v2 on Render if OOM)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Whisper fallback
WHISPER_MODEL=base

# Optional: use browser cookies when yt-dlp hits YouTube bot checks (chrome, firefox, edge)
YTDLP_COOKIES_FROM_BROWSER=

# App
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,https://hashverse-two.vercel.app
